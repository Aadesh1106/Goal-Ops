# ============================================================
# GoalOps Enterprise — Local Environment Variables Template
# ============================================================
# Copy this file to '.env.local' and fill in your Supabase project keys.
# WARNING: NEVER commit '.env.local' to public Git repositories!

# --- Supabase Configuration ---
# Your Supabase project URL (e.g., https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Your Supabase Anon (public) key found in Project Settings -> API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Supabase Service Role key (private service token, needed for secure Server Actions)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- App Settings ---
# URL for local dev environment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Name of the portal platform
NEXT_PUBLIC_APP_NAME=GoalOps Enterprise
